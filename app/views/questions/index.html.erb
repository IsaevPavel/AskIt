<h1 class="mb-4">Questions</h1>

<%= link_to 'New question', new_question_path, class: 'btn btn-secondary' %>
<%#= @questions.inspect %>
<br>
<% @questions.each do |question| %>
  <article class="card mt-2" >
    <div class="card-body">
      <h4><%= question.title %></h4>
      <section class="card-text">
        <time datetime="<%= question.formatted_created_at %>">
          <small><%= question.formatted_created_at %></small>
        </time>
        <p class="my-2">
          <%= question.body %>
        </p>
      </section>
      <br>
      <%= link_to 'Show', question_path(question), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Edit', edit_question_path(question), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Delete', question_path(question), class: 'btn btn-dark btn-sm',
                  data: { turbo_method: :delete, confirm: 'Are you sure?' } %>
    </div>
  </article>
<% end %>