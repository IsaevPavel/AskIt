<% provide :page_title, 'Show question' %>
<% currently_at 'Questions' %>

<h1 class="mb-4" ><%= @question.title %></h1>
<time datetime="<%= @question.formatted_created_at %>" >DateTime:
  <%= @question.formatted_created_at %>
</time>
<br>

<div>
  <%= sanitize @question.body %>
</div>
<div class="btn-group">
  <%= link_to 'Edit', edit_question_path(@question), class: 'btn btn-secondary btn-sm' %>
  <%= link_to 'Delete', question_path(@question), class: 'btn btn-dark btn-sm',
              data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } %>
</div>
<hr class="my-3">

<h1>Write your answer</h1>

<%= render 'answers/form' %>

<hr class="my-3">

<h1>Answers</h1>

<%= paginate @answers %>

<%#= @question.answers.inspect %>

<%= render partial: 'answers/answer', collection: @answers,
           as: :answer, locals: { question: @question } %>

<%= paginate @answers %>
