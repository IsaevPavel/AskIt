<%= tag.article class: "card mt-2", id: dom_id(answer) do%>
  <div class="card-body">
    <time datetime="<%= answer.formatted_created_at %>">DateTime:
      <%= answer.formatted_created_at %>
    </time>
    <div>
      <%= sanitize answer.body %>
    </div>

      <%= link_to 'Edit', edit_question_answer_path(question, answer), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Delete', question_answer_path(question, answer), class: 'btn btn-dark btn-sm',
                  data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } %>
  </div>
    <% end %>